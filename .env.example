# =============================================================================
# dss-system — environment variables for the monorepo Docker Compose stack.
# Copy this file to .env and fill in every secret with strong, unique values.
# =============================================================================

# -----------------------------------------------------------------------------
# Core public identity / URLs
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=https://id.dualsubstrate.com
DEFAULT_DID_HOST=id.dualsubstrate.com
ISSUER_DID=did:web:id.dualsubstrate.com

BACKEND_BASE_URL=http://backend:8000
MIDDLEWARE_BASE_URL=http://middleware:8001
CHAT_BASE_URL=http://chat-surface:3001
CONTROL_PLANE_BASE=http://control-plane:3000
BENCHMARK_DECODER_BASE_URL=http://coord-demo:3002

API_BASE=http://middleware:8001
DUALSUBSTRATE_API=http://middleware:8001
DUALSUBSTRATE_API_LOCAL=http://middleware:8001
DUALSUBSTRATE_API_KEY=
DUALSUBSTRATE_API_KEY_LOCAL=

BACKEND_ADMIN_BASE_URL=http://backend:8000
DUALSUBSTRATE_BACKEND_ADMIN_BASE=http://backend:8000
DUALSUBSTRATE_CONTROL_PLANE_BASE=http://control-plane:3000
DUALSUBSTRATE_AUTH_BASE=http://backend:8000

LOCAL_CHAT_BASE_URL=http://chat-surface:3001
LOCAL_API=http://backend:8000
CLOUD_API=http://backend:8000

# -----------------------------------------------------------------------------
# Secrets — generate strong values and never commit them.
# -----------------------------------------------------------------------------
FASTHTML_SECRET_KEY=
AUTH_SESSION_TOKEN_SECRET=
E6_SYNC_HMAC_KEY=
E6_SYNC_HMAC_KEYS={}
OPENROUTER_API_KEY=
ADMIN_TOKEN=
TRUST_ANCHOR_ADMIN_TOKEN=
MIDDLEWARE_ADMIN_TOKEN=
BACKEND_ADMIN_TOKEN=
MCP_AUTH_TOKEN=

DID_PUBLIC_JWK_JSON=
DID_SECONDARY_PUBLIC_JWK_JSON=
DID_VERIFICATION_KEY_X=REPLACE_ME
DID_VERIFICATION_METHOD_ID=
WALT_ID_ISSUER_DID=did:web:id.dualsubstrate.com
WALT_ID_ISSUER_PUBLIC_JWK_JSON=
WALT_ID_ISSUER_KEY_JWK_JSON=
WALT_ID_CALLBACK_API_KEY=
WALT_ID_CREDENTIAL_CONFIGURATION_ID=DssIdentity_jwt_vc_json

# -----------------------------------------------------------------------------
# Trust anchor / organisation
# -----------------------------------------------------------------------------
TRUST_ANCHOR_ISSUER_DID=did:web:id.dualsubstrate.com
TRUST_ANCHOR_PUBLIC_BASE_URL=https://id.dualsubstrate.com
TRUST_ANCHOR_ORGANISATION_NAME=Dual Substrate
TRUST_ANCHOR_ORGANISATION_URI=https://dualsubstrate.com
TRUST_ANCHOR_ORGANISATION_REGISTRATION_REF=
DEFAULT_ORGANISATION_URI=https://dualsubstrate.com

# -----------------------------------------------------------------------------
# WebAuthn / domain handling
# -----------------------------------------------------------------------------
AUTH_WEBAUTHN_RP_ID=id.dualsubstrate.com
AUTH_WEBAUTHN_RP_NAME=Dual Substrate
AUTH_WEBAUTHN_ALLOWED_ORIGINS=https://id.dualsubstrate.com,https://chat.dualsubstrate.com
AUTH_WEBAUTHN_CHALLENGE_TTL_SECONDS=300
AUTH_WEBAUTHN_RP_ID_OVERRIDE=
BASE_DOMAIN=dualsubstrate.com
DEFAULT_HOST=id.dualsubstrate.com
DEFAULT_CHAT_HOST=chat.dualsubstrate.com
DUALSUBSTRATE_COOKIE_DOMAIN=.dualsubstrate.com

# -----------------------------------------------------------------------------
# App IDs and runtime defaults
# -----------------------------------------------------------------------------
DEFAULT_LEDGER_ID=LOAM
CHAT_SURFACE_ID=surface:chat:primary
DEFAULT_SESSION_ID=demo-session
DEMO_LEDGER_ID=LOAM
DEMO_OVERRIDE_DEFAULT_LEDGER=s2

FRONTEND_CONTEXT_ID=ctx:frontend:local
FRONTEND_TENANT_ID=tenant:demo
FRONTEND_PRINCIPAL_ID=demo-user
FRONTEND_PRINCIPAL_TYPE=user
FRONTEND_ENTITY_MODE=ledger

CODEX_PRINCIPAL_DID=did:web:id.dualsubstrate.com:principals:agent:openai:codex
HISTORY_DISCOVERY_LIMIT=100

# -----------------------------------------------------------------------------
# LLM / OpenRouter
# -----------------------------------------------------------------------------
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o
LLM_BASE_URL=
LLM_API_KEY=
OPENROUTER_MAX_TOKENS=0
DISABLE_RESPONSE_TOKEN_LIMITS=1
ENABLE_LOCAL_LLM=false
LLM_SUPPORTS_TOOLS=true
LLM_FORCE_SYSTEM_SIGNALS=false

# -----------------------------------------------------------------------------
# E6 sync / MCP
# -----------------------------------------------------------------------------
E6_SYNC_ISSUER=prime:issuer:middleware
E6_SYNC_SUBJECT=prime:subject:middleware
E6_SYNC_PRIVATE_KEY_HEX=
E6_SYNC_KEY_ID=1
E6_SYNC_LEDGER_ID=ledger-local
E6_SYNC_ORIGIN_NODE=middleware-local
E6_SYNC_ORIGIN_REPO=dss-system
E6_SYNC_MESSAGE=dss-system ed25519 smoke

MCP_PUBLIC_BASE_URL=
MCP_AUTH_REQUIRED=true
MCP_SERVER_BACKEND_BASE=http://backend:8000

ADAPTIVE_EXECUTION_ENABLED=false
ADAPTIVE_EXECUTION_FORCE_PROFILE=
ADAPTIVE_EXECUTION_LOCAL_PROVIDER_MARKERS=ollama,llama,local
CONTROL_PLANE_REGISTRY_PATH=./data/control_plane_registry.json

# -----------------------------------------------------------------------------
# Backend behaviour
# -----------------------------------------------------------------------------
ADMIN_TOKEN=
BACKEND_CORS_ORIGIN_REGEX=.*
CHAT_HARDENING_LEVEL=3
ENABLE_INTROSPECT=1
ENABLE_LEDGER_MANAGEMENT=true
HTTP_TIMEOUT=10.0
ATTACHMENT_MAX_BYTES=52428800
ASSURANCE_CHALLENGE_REQUIRED=0
ASSURANCE_ENFORCE=0
ASSURANCE_MAX_AGE_SEC=900
ASSURANCE_MODEL_KEYS_JSON=
ASSURANCE_SHARED_SECRET=
AUTONOMY_POLICY=balanced

AUTH_SESSION_TOKEN_TTL_SECONDS=3600
AUTH_SESSION_TOKEN_REFRESH_TTL_SECONDS=86400
AUTH_SESSION_TOKEN_ISSUER=ds-middleware
AUTH_SESSION_TOKEN_AUDIENCE=ds-backend

AUTH_REVOCATION_TOKEN=
AUTH_PRINCIPAL_MODE=compat

# -----------------------------------------------------------------------------
# Middleware behaviour
# -----------------------------------------------------------------------------
MIDDLEWARE_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
ENTRA_OIDC_CLIENT_ID=
ENTRA_OIDC_CLIENT_SECRET=
ENTRA_OIDC_TENANT_ID=2f013f08-f893-436f-becc-9f82d02ca76d
ENTRA_OIDC_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Dashboard / control-plane
# -----------------------------------------------------------------------------
DSS_DATA_DIR=./data
BENCHMARK_PUBLICATION_PATH=./data/benchmarks
BENCHMARK_ARTIFACT_ROOT=
BENCHMARK_PUBLICATION_OPERATOR_DIDS=
BENCHMARK_TOP_K=
BENCHMARK_REFERENCE_ONLY_SUITES=
BENCHMARK_PHASE1_MAX_AGE_HOURS=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
PRINCIPAL_INVITE_EMAIL_FROM=
PROFILE_REQUEST_EMAIL_FROM=
PROFILE_REQUEST_EMAIL_TO=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

LOCAL_CHAT_LABEL=Local Offline Chat
LOCAL_CHAT_SYNC_MODE=shared-ledger-sync

# -----------------------------------------------------------------------------
# coord-demo
# -----------------------------------------------------------------------------
FEEDBACK_ACTOR_ID=human:decoder
FEEDBACK_ACTOR_TYPE=human
VERIFIER_PORTAL_ID=web4_decoder_app
VERIFIER_IDENTITY=human:decoder
PRINCIPAL_ID=demo-user
PRINCIPAL_TYPE=human
TENANT_ID=demo

# -----------------------------------------------------------------------------
# ds-review smoke / probe scripts
# -----------------------------------------------------------------------------
DSS_BACKEND_URL=http://backend:8000
DSS_CHAT_URL=http://chat-surface:3001/api/chat/smart_stream
DSS_LEDGER_ID=LOAM
DSS_OPERATOR_ID=ops-admin
DSS_SURFACE_ID=surface:chat:primary
CONTROL_PLANE_URL=http://backend:8000

# -----------------------------------------------------------------------------
# Demo tooling
# -----------------------------------------------------------------------------
DEMO_UI_URL=http://chat-surface:3001
DEMO_HEALTH_URL=http://chat-surface:3001/health
DEMO_MAKE_CMD=make
DEMO_LAUNCH_TARGET=launch-all
DEMO_BOOT_TIMEOUT=300
DEMO_STACK_LOG=/tmp/ds-demo-stack.log
DEMO_WINDOW_TITLE=DS Frontend Demo
