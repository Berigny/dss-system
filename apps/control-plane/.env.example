PUBLIC_BASE_URL=https://id.dualsubstrate.com
ISSUER_DID=did:web:id.dualsubstrate.com
MIDDLEWARE_BASE_URL=http://127.0.0.1:5001
# Optional admin token for middleware mutations (OpenRouter key, etc.).
# Defaults to TRUST_ANCHOR_ADMIN_TOKEN if unset.
MIDDLEWARE_ADMIN_TOKEN=
CHAT_BASE_URL=https://chat.dualsubstrate.com
BENCHMARK_DECODER_BASE_URL=https://decoder.dualsubstrate.com
LOCAL_CHAT_BASE_URL=
LOCAL_CHAT_LABEL=Local Offline Chat
LOCAL_CHAT_SYNC_MODE=shared-ledger-sync

# Preferred: full public JWK JSON for the DID document verification method.
# Example:
# DID_PUBLIC_JWK_JSON={"kty":"OKP","crv":"Ed25519","x":"REPLACE_ME"}
DID_PUBLIC_JWK_JSON=

# Fallback testing-only path if you only have the Ed25519 x value.
DID_VERIFICATION_KEY_X=

# Optional secondary verification method for walt.id issuance key.
# If unset, a fallback public JWK is baked into app.py for pilot deployment.
DID_SECONDARY_PUBLIC_JWK_JSON=

# Bootstrap / verification helpers
BACKEND_BASE_URL=http://127.0.0.1:8000
TRUST_ANCHOR_ADMIN_TOKEN=
TRUST_ANCHOR_ADMIN_PRINCIPAL_ID=ops-admin
TRUST_ANCHOR_ADMIN_PRINCIPAL_TYPE=admin
TRUST_ANCHOR_CONTEXT_ID=ctx:dashboard:trust-anchor-bootstrap
TRUST_ANCHOR_LEDGER_ID=default
