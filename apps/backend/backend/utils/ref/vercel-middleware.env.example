# Vercel middleware
# Backend connectivity
DUALSUBSTRATE_API=https://<fly-backend-domain>
DUALSUBSTRATE_API_KEY=
DEFAULT_LEDGER_ID=default
DEFAULT_SESSION_ID=demo-session
HTTP_TIMEOUT=20

# Model routing
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
ENABLE_LOCAL_LLM=false
LLM_BASE_URL=
LLM_API_KEY=dummy

# Adaptive execution
ADAPTIVE_EXECUTION_ENABLED=true
ADAPTIVE_EXECUTION_FORCE_PROFILE=
ADAPTIVE_EXECUTION_LOCAL_PROVIDER_MARKERS=ollama,localhost,127.0.0.1,/v1

# OpenAI compat and CORS
OPENAI_COMPAT_USE_PIPELINE=1
OPENAI_COMPAT_PIPELINE_ENGINE=middleware
MIDDLEWARE_CORS_ORIGINS=https://<frontend-vercel-domain>

# Sync daemon (optional worker mode)
LOCAL_API=http://127.0.0.1:8080
CLOUD_API=https://<fly-backend-domain>
SYNC_LEDGER_ID_H64=0000000000000000
SYNC_PEER_ID=middleware-sync-daemon
SYNC_BATCH_LIMIT=200
SYNC_INTERVAL_SECONDS=60
