# Fly.io backend (ledger authority)
# Required
DB_PATH=/data
ADMIN_TOKEN=change-me

# Sync crypto (preferred)
E6_SYNC_ED25519_KEYS={"1":"<ed25519-public-key-hex-32-bytes>"}
# Optional HMAC fallback (legacy/dev)
E6_SYNC_HMAC_KEY=change-me

# Model/provider routing (set one or more)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
LLM_BASE_URL=
LLM_API_KEY=dummy
LLM_MODEL=llama3.2:latest

# API/CORS
FASTAPI_ROOT=https://<fly-app>.fly.dev
# Comma-separated origins allowed by backend CORS middleware.
MIDDLEWARE_CORS_ORIGINS=https://<middleware-vercel-domain>,https://<frontend-vercel-domain>
# Optional regex for preview domains. Set empty to disable regex matching.
BACKEND_CORS_ORIGIN_REGEX=https://<frontend-project>.*\\.vercel\\.app

# Security/ops
GIT_SHA=
ASSURANCE_SHARED_SECRET=

# Tenancy/Authz rollout controls (staged hardening)
# Stage A (compat baseline):
LEDGER_AUTHZ_MODE=allow_all
LEDGER_CONTEXT_MODE=compat
RESOLVER_NAMESPACE_GATE_MODE=compat

# Stage B/C/D (set when advancing hardening gates):
# LEDGER_AUTHZ_MODE=registry
# LEDGER_AUTHZ_UNKNOWN_LEDGER_POLICY=allow
# LEDGER_AUTHZ_ADMIN_PRINCIPAL_TYPES=admin,service
# LEDGER_CONTEXT_MODE=enforce
# RESOLVER_NAMESPACE_GATE_MODE=strict
# LEDGER_SCOPE_STRICT=true
# LEDGER_CONTEXT_ID_MODE=enforce
# LEDGER_CONTEXT_BINDING_MODE=enforce
# LEDGER_NAMESPACE_SOURCE=ledger_id
